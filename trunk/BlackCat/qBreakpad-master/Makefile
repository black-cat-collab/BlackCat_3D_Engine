qmake: FORCE
	@$(QMAKE) -o Makefile qBreakpad.pro -spec win32-msvc "CONFIG+=qtquickcompiler"

qmake_all: sub-handler-qmake_all sub-demo-qmake_all sub-tests-qmake_all FORCE

make_first: sub-handler-make_first-ordered sub-demo-make_first-ordered sub-tests-make_first-ordered  FORCE
all: sub-handler-all-ordered sub-demo-all-ordered sub-tests-all-ordered  FORCE
clean: sub-handler-clean-ordered sub-demo-clean-ordered sub-tests-clean-ordered  FORCE
distclean: sub-handler-distclean-ordered sub-demo-distclean-ordered sub-tests-distclean-ordered  FORCE
	-$(DEL_FILE) Makefile
	-$(DEL_FILE) .qmake.stash
install_subtargets: sub-handler-install_subtargets-ordered sub-demo-install_subtargets-ordered sub-tests-install_subtargets-ordered FORCE
uninstall_subtargets: sub-handler-uninstall_subtargets-ordered sub-demo-uninstall_subtargets-ordered sub-tests-uninstall_subtargets-ordered FORCE

sub-handler-debug_ordered:
	@if not exist handler\ mkdir handler\ & if not exist handler\ exit 1
	@set MAKEFLAGS=$(MAKEFLAGS)
	cd handler\ && ( if not exist Makefile $(QMAKE) -o Makefile C:\Users\Administrator\Desktop\555\qBreakpad-master\handler\handler.pro -spec win32-msvc "CONFIG+=qtquickcompiler" ) && $(MAKE) -f Makefile debug
